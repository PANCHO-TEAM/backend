// Генератор создает Prisma Client, который используется в Node.js-коде проекта.
generator client {
  provider = "prisma-client-js"
}

// Источником данных для Prisma служит база PostgreSQL.
datasource db {
  provider = "postgresql"
}

// Набор допустимых способов связи, которые пользователь может указать в заказе.
enum ContactType {
  PHONE
  EMAIL
  TELEGRAM
}

// Модель товара: хранит основные данные каталога и связанные с ним заказы.
model Product {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  weight      Float
  diameter    Float
  servings    Int
  images      String[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime? @updatedAt
  orders      Order[]
}

// Модель заказа: хранит данные клиента и необязательную ссылку на товар.
model Order {
  id           Int      @id @default(autoincrement())
  name         String
  message      String
  contactType  ContactType
  contactValue String
  
  productId    Int?
  product      Product? @relation(fields: [productId], references: [id])
  createdAt    DateTime @default(now())
}
